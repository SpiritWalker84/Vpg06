# =============================================================================
# Telegram
# =============================================================================
TELEGRAM_BOT_TOKEN=
LOG_LEVEL=INFO

# =============================================================================
# OpenAI-compatible API (ProxyAPI/OpenAI)
# =============================================================================
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.proxyapi.ru/openai/v1
# Запасной ключ для совместимости
# OPENAI_BASE_URL=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# =============================================================================
# Weaviate Cloud
# =============================================================================
WEAVIATE_URL=https://xxxxxx.weaviate.network
WEAVIATE_API_KEY=
WEAVIATE_COLLECTION_NAME=Vpg05Memory

# Порог похожести для дедупликации памяти (0..1). Слишком низкий порог часто даёт ложные совпадения
# (любая фраза «приклеивается» к ближайшему соседу) → в логах почти всегда будет updated.
# Для text-embedding-3-* обычно разумный старт: 0.72–0.85 (подберите под ваши фразы).
SIMILARITY_THRESHOLD=0.78
