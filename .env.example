# =============================================================================
# Telegram
# =============================================================================
TELEGRAM_BOT_TOKEN=
LOG_LEVEL=INFO

# =============================================================================
# OpenAI-compatible API (ProxyAPI/OpenAI)
# =============================================================================
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.proxyapi.ru/openai/v1
# Запасной ключ для совместимости
# OPENAI_BASE_URL=
OPENAI_CHAT_MODEL=gpt-4o-mini
# Для vision (описание собаки по фото); по умолчанию совпадает с OPENAI_CHAT_MODEL
# OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# =============================================================================
# Weaviate Cloud (Haystack WeaviateDocumentStore)
# =============================================================================
WEAVIATE_URL=https://xxxxxx.weaviate.network
WEAVIATE_API_KEY=
# Имя коллекции; для Haystack нужна схема с полями haystack (см. README). Старую Vpg05Memory не смешивать.
WEAVIATE_COLLECTION_NAME=Vpg06HaystackMemory

# Сколько фрагментов памяти подставлять в системный промпт
MEMORY_TOP_K=8
# Макс. сообщений в краткой истории чата (роли user/assistant/tool)
CHAT_HISTORY_MAX_MESSAGES=24
# Лимит шагов агента (вызовы LLM / инструменты)
MAX_AGENT_STEPS=12
